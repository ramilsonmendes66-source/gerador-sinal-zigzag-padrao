<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Dragon Trader IA</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600;700;800&family=Space+Mono:wght@400;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080d14;--bg2:#0d1520;--bg3:#111d2e;--bg4:#182438;
  --cyan:#00e5c0;--cyan2:#00b89a;--cyan3:#008870;
  --green:#00ff88;--green2:#00c96d;--green3:#007a3d;
  --red:#ff3d5a;--red2:#cc2040;
  --yellow:#ffd000;--yellow2:#ccaa00;
  --orange:#ff8c00;--orange2:#cc7000;
  --purple:#a855f7;--purple2:#7c3aed;
  --gray:#7a9aaa;--gray2:#445566;
  --border:#1a2d40;--border2:#243d55;
  --text:#c8e4f0;--text2:#6a8fa0;
}
body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden}

/* ── HEADER ── */
.header{background:var(--bg2);border-bottom:2px solid var(--cyan3);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-dragon{width:38px;height:38px;border-radius:8px;background:linear-gradient(135deg,#003322,var(--cyan3));display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--cyan)}
.logo-text{font-size:14px;font-weight:800;color:var(--cyan);letter-spacing:1.5px;line-height:1.2}
.logo-sub{font-size:9px;color:var(--gray2);letter-spacing:2px;text-transform:uppercase}
.hdr-stats{display:flex;gap:8px;flex-wrap:wrap}
.hpill{background:var(--bg3);border:1px solid var(--border2);border-radius:12px;padding:3px 10px;font-size:11px;color:var(--gray)}
.hpill b{color:var(--cyan)}
.dot{width:7px;height:7px;border-radius:50%;background:var(--green);display:inline-block;margin-right:4px;animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* ── LAYOUT ── */
.layout{display:grid;grid-template-columns:300px 1fr 300px;gap:10px;padding:10px;min-height:calc(100vh - 62px)}

/* ── PANELS ── */
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden;display:flex;flex-direction:column}
.ph{background:var(--bg3);border-bottom:1px solid var(--border);padding:7px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.ph-title{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--cyan);text-transform:uppercase}
.pb{padding:12px;flex:1;overflow-y:auto}
.pb::-webkit-scrollbar{width:3px}
.pb::-webkit-scrollbar-thumb{background:var(--cyan3);border-radius:2px}

/* ── CLOCK ── */
.clock-panel{background:linear-gradient(135deg,var(--bg3),var(--bg4));border-radius:12px;padding:12px;margin-bottom:12px;text-align:center;border:1px solid var(--cyan3)}
.current-time{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--cyan);letter-spacing:3px}
.current-date{font-size:10px;color:var(--gray);margin-top:3px}
.countdown{font-family:'Space Mono',monospace;font-size:18px;font-weight:700;color:var(--yellow);margin-top:8px}
.countdown-label{font-size:9px;color:var(--gray2);letter-spacing:2px}
.status-badge{display:inline-block;background:var(--bg4);border-radius:20px;padding:4px 12px;font-size:10px;margin-top:8px}
.status-badge.synced{color:var(--green);border:1px solid var(--green3)}
.status-badge.waiting{color:var(--yellow);border:1px solid var(--yellow2)}

/* ── SIGNAL AUTO ── */
.signal-auto{background:var(--bg3);border-radius:10px;padding:14px;margin-top:12px;border:2px solid var(--border2);transition:.3s}
.signal-auto.CALL{border-color:var(--green2);background:rgba(0,255,136,.08)}
.signal-auto.PUT{border-color:var(--red2);background:rgba(255,61,90,.08)}
.signal-auto.NO{border-color:var(--yellow2);background:rgba(255,208,0,.05)}
.signal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.signal-badge{background:var(--bg4);border-radius:6px;padding:3px 10px;font-size:9px;color:var(--gray)}
.signal-type{font-size:24px;font-weight:800;letter-spacing:2px}
.signal-type.CALL{color:var(--green)}
.signal-type.PUT{color:var(--red)}
.signal-type.NO{color:var(--yellow)}
.signal-details{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.signal-detail{background:var(--bg4);border-radius:6px;padding:6px;text-align:center}
.signal-detail-label{font-size:8px;color:var(--gray2);text-transform:uppercase}
.signal-detail-value{font-size:12px;font-weight:700;color:var(--cyan);font-family:'Space Mono',monospace}
.signal-prob{height:4px;background:var(--bg);border-radius:2px;margin-top:10px;overflow:hidden}
.signal-prob-fill{height:100%;transition:width .3s}
.signal-prob-fill.CALL{background:var(--green2)}
.signal-prob-fill.PUT{background:var(--red2)}
.signal-prob-fill.NO{background:var(--yellow2)}

/* ── CAMERA / UPLOAD ── */
.camera-section{margin-bottom:12px}
.cam-btns{display:flex;gap:6px;margin-bottom:8px}
.cam-btn{flex:1;background:var(--bg3);border:1.5px solid var(--cyan3);color:var(--cyan);border-radius:6px;padding:9px 8px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Exo 2',sans-serif;letter-spacing:1px;transition:.2s;display:flex;align-items:center;justify-content:center;gap:5px}
.cam-btn:hover{background:rgba(0,229,192,.1)}
.cam-btn.gallery{border-color:var(--purple2);color:var(--purple)}
.cam-btn.gallery:hover{background:rgba(168,85,247,.1)}
.drop{border:2px dashed var(--border2);border-radius:8px;padding:16px;text-align:center;cursor:pointer;transition:.2s;min-height:110px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px}
.drop:hover,.drop.drag{border-color:var(--cyan2);background:rgba(0,229,192,.05)}
.drop-icon{font-size:24px;color:var(--cyan3)}
.drop-txt{font-size:10px;color:var(--gray);line-height:1.5}
#fi{display:none}
#fiCamera{display:none}
#fiGallery{display:none}
.preview{width:100%;max-height:200px;border-radius:6px;object-fit:contain;margin-top:8px;display:block;background:var(--bg3)}
.img-buttons{display:flex;gap:8px;margin-top:8px}
.img-clear-btn{background:rgba(255,61,90,.15);border:1px solid var(--red2);color:var(--red);border-radius:4px;padding:5px 12px;font-size:10px;font-weight:700;cursor:pointer;flex:1}
.img-gen-btn{background:var(--cyan3);color:#000;border:none;border-radius:4px;padding:5px 12px;font-size:10px;font-weight:800;cursor:pointer;flex:2;font-family:'Exo 2',sans-serif;letter-spacing:1px}
.img-gen-btn:hover{background:var(--cyan2)}

/* ── PAR / MERCADO ── */
.market-tabs{display:flex;gap:4px;margin-bottom:8px}
.mtab{flex:1;background:var(--bg3);border:1px solid var(--border2);color:var(--gray);border-radius:5px;padding:6px 8px;font-size:10px;font-weight:700;cursor:pointer;font-family:'Exo 2',sans-serif;letter-spacing:1px;transition:.2s;text-align:center}
.mtab.active.open{background:rgba(0,255,136,.15);border-color:var(--green3);color:var(--green)}
.mtab.active.closed{background:rgba(255,61,90,.15);border-color:var(--red2);color:var(--red)}
.market-badge{display:inline-flex;align-items:center;gap:4px;border-radius:10px;padding:2px 8px;font-size:9px;font-weight:700;letter-spacing:1px}
.market-badge.open{background:rgba(0,255,136,.15);color:var(--green);border:1px solid var(--green3)}
.market-badge.closed{background:rgba(255,61,90,.15);color:var(--red);border:1px solid var(--red2)}

.par-row{display:flex;gap:6px;margin-top:8px;align-items:center}
.par-sel{flex:1;background:var(--bg3);border:1px solid var(--border2);color:var(--text);border-radius:4px;padding:5px 8px;font-size:11px}
.par-sel:focus{outline:none;border-color:var(--cyan3)}
.par-det{background:var(--bg4);border:1px solid var(--cyan3);border-radius:4px;padding:5px 10px;font-size:10px;font-weight:700;color:var(--cyan);white-space:nowrap}

.sigbox{margin-top:10px;border-radius:8px;padding:14px;text-align:center;border:2px solid var(--border);background:var(--bg3)}
.sigdir{font-size:18px;font-weight:800;letter-spacing:2px;margin-bottom:3px}

/* ── PAIRS GRID ── */
.pairs-section{margin-bottom:10px}
.pairs-section-title{font-size:9px;font-weight:700;color:var(--gray2);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;padding-bottom:4px;border-bottom:1px solid var(--border)}
.pairs-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:6px}
.pair-chip{background:var(--bg3);border:1px solid var(--border2);border-radius:5px;padding:5px 8px;font-size:10px;font-weight:700;cursor:pointer;transition:.2s;display:flex;justify-content:space-between;align-items:center;font-family:'Space Mono',monospace}
.pair-chip:hover{border-color:var(--cyan3)}
.pair-chip.active{border-color:var(--cyan2);background:rgba(0,229,192,.08);color:var(--cyan)}
.pair-chip .pair-vol{font-size:7px;font-weight:400;color:var(--gray2);font-family:'Exo 2',sans-serif}
.pair-chip.open-mkt .pair-status{width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0;margin-left:4px}
.pair-chip.closed-mkt .pair-status{width:5px;height:5px;border-radius:50%;background:var(--red);flex-shrink:0;margin-left:4px}

/* ── BANK ── */
.bank-btns{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap}
.bank-add{background:var(--bg3);border:1px solid var(--cyan3);color:var(--cyan);border-radius:4px;padding:5px 12px;font-size:10px;font-weight:700;cursor:pointer}
.bank-save{background:var(--bg3);border:1px solid var(--green3);color:var(--green);border-radius:4px;padding:5px 12px;font-size:10px;font-weight:700;cursor:pointer}
.bank-clr-all{background:var(--bg3);border:1px solid var(--border2);color:var(--red);border-radius:4px;padding:5px 12px;font-size:10px;font-weight:700;cursor:pointer}
#bfi{display:none}
.bgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(70px,1fr));gap:6px;max-height:200px;overflow-y:auto}
.bthumb{position:relative;border-radius:5px;overflow:hidden;border:2px solid var(--border);cursor:pointer;aspect-ratio:4/3;background:var(--bg3)}
.bthumb img{width:100%;height:100%;object-fit:cover}
.bthumb-remove{position:absolute;top:2px;right:2px;background:rgba(0,0,0,.8);color:var(--red);border:none;border-radius:3px;font-size:8px;padding:2px 4px;cursor:pointer}
.bempty{padding:24px;text-align:center;color:var(--gray2);font-size:11px}

/* ── LOG ── */
.llog{max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:5px}
.litem{background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:6px 10px;display:grid;grid-template-columns:1fr auto auto auto;gap:6px;align-items:center;font-size:10px}
.lsig{font-weight:800}
.lsig.CALL{color:var(--green)}
.lsig.PUT{color:var(--red)}
.lsig.NO{color:var(--yellow)}
.lempty{text-align:center;color:var(--gray2);font-size:10px;padding:14px}

/* ── TOAST ── */
.toast{position:fixed;bottom:16px;right:16px;background:var(--bg3);border:1px solid var(--cyan3);border-radius:6px;padding:8px 14px;font-size:11px;color:var(--cyan);z-index:9999;opacity:0;transform:translateY(8px);transition:.25s;max-width:260px}
.toast.on{opacity:1;transform:translateY(0)}

/* ── FILTERS ── */
.filter-row{display:flex;justify-content:space-between;align-items:center;font-size:10px;padding:4px 0;border-bottom:1px solid var(--border)}
.filter-row:last-child{border-bottom:none}
.filter-ok{color:var(--green);font-weight:700;font-size:13px}
.filter-no{color:var(--red);font-weight:700;font-size:13px}
.filter-wait{color:var(--gray2);font-size:12px}

/* ── MOBILE RESPONSIVE ── */
@media (max-width:900px){
  .layout{grid-template-columns:1fr;gap:8px;padding:8px}
  .side-right{order:3}
}
@media (max-width:600px){
  .layout{padding:6px;gap:6px}
  .header{padding:8px 12px}
  .hpill{font-size:10px;padding:3px 7px}
  .current-time{font-size:22px}
}

/* ── CAMERA LIVE PREVIEW ── */
.camera-live{position:fixed;top:0;left:0;width:100%;height:100%;background:#000;z-index:9000;display:none;flex-direction:column;align-items:center;justify-content:center}
.camera-live.active{display:flex}
.camera-live video{width:100%;max-height:70vh;object-fit:contain}
.camera-live-controls{display:flex;gap:16px;margin-top:16px}
.cam-capture-btn{background:var(--cyan3);color:#000;border:none;border-radius:50%;width:64px;height:64px;font-size:24px;cursor:pointer;font-weight:700;transition:.2s}
.cam-capture-btn:hover{background:var(--cyan2);transform:scale(1.08)}
.cam-cancel-btn{background:rgba(255,61,90,.3);border:2px solid var(--red);color:var(--red);border-radius:50%;width:48px;height:48px;font-size:18px;cursor:pointer;margin-top:8px}
.canvas-hidden{display:none}

/* ── SIGNAL GENERATING ANIMATION ── */
@keyframes pulse-border{
  0%,100%{box-shadow:0 0 0 0 rgba(0,229,192,.4)}
  50%{box-shadow:0 0 0 8px rgba(0,229,192,0)}
}
.generating{animation:pulse-border .8s ease-out 2}
</style>
</head>
<body>

<!-- CAMERA LIVE PREVIEW -->
<div class="camera-live" id="cameraLive">
  <video id="cameraVideo" autoplay playsinline muted></video>
  <canvas id="cameraCanvas" class="canvas-hidden"></canvas>
  <div class="camera-live-controls">
    <button class="cam-cancel-btn" onclick="closeLiveCamera()" title="Cancelar">✕</button>
    <button class="cam-capture-btn" onclick="captureFromCamera()" title="Capturar">📷</button>
  </div>
  <div style="font-size:11px;color:var(--gray);margin-top:10px;letter-spacing:1px">POSICIONE O GRÁFICO E CAPTURE</div>
</div>

<!-- HEADER -->
<div class="header">
  <div class="logo">
    <div class="logo-dragon">DT</div>
    <div>
      <div class="logo-text">DRAGON TRADER IA</div>
      <div class="logo-sub"><span class="dot"></span>Real-Time Sync · M1 · Auto Signals</div>
    </div>
  </div>
  <div class="hdr-stats">
    <div class="hpill">Banco: <b id="hb">0</b>/100</div>
    <div class="hpill">Sinais: <b id="hs">0</b></div>
    <div class="hpill">Win Rate: <b id="hw">—</b></div>
    <div class="hpill" id="mktStatusPill">Mercado: <b id="mktLabel" style="color:var(--green)">ABERTO</b></div>
  </div>
</div>

<div class="layout">

<!-- ═══ ESQUERDA: GRÁFICO E CONFIG ═══ -->
<div style="display:flex;flex-direction:column;gap:10px">
  <div class="panel">
    <div class="ph">
      <span class="ph-title">📸 Gráfico M1</span>
      <span style="font-size:9px;color:var(--gray)">ZigZag 5·12·3</span>
    </div>
    <div class="pb">

      <!-- MARKET TYPE SELECTOR -->
      <div class="market-tabs">
        <button class="mtab active open" id="tabOpen" onclick="switchMarket('open')">📈 ABERTO</button>
        <button class="mtab closed" id="tabClosed" onclick="switchMarket('closed')">📊 FECHADO</button>
      </div>

      <!-- CAMERA SECTION -->
      <div class="camera-section">
        <div class="cam-btns">
          <button class="cam-btn" onclick="openLiveCamera()" title="Abrir câmera">
            📷 CÂMERA
          </button>
          <button class="cam-btn gallery" onclick="document.getElementById('fiGallery').click()" title="Galeria">
            🖼 GALERIA
          </button>
        </div>
        <input type="file" id="fiGallery" accept="image/*">
        <input type="file" id="fiCamera" accept="image/*" capture="environment">

        <div class="drop" id="drop" onclick="document.getElementById('fiGallery').click()">
          <div class="drop-icon">⬆</div>
          <div class="drop-txt">Arraste ou clique para inserir<br>imagem do gráfico M1 com ZigZag</div>
        </div>
        <input type="file" id="fi" accept="image/*">

        <div id="prevwrap" style="display:none">
          <img id="prev" class="preview" src="" alt="Gráfico carregado">
          <div class="img-buttons">
            <button class="img-clear-btn" onclick="clearCurrentImage()">🗑️ LIMPAR</button>
            <button class="img-gen-btn" id="manualGenBtn" onclick="triggerManualSignal()">⚡ GERAR SINAL</button>
          </div>
        </div>
      </div>

      <!-- PAR -->
      <div id="pairSelectorArea">
        <div id="openPairs" class="pairs-section">
          <div class="pairs-section-title">🟢 Mercado Aberto — Forex OTC</div>
          <div class="pairs-grid" id="openPairsGrid"></div>
        </div>
        <div id="closedPairs" class="pairs-section" style="display:none">
          <div class="pairs-section-title">🔴 Mercado Fechado — OTC/Digital</div>
          <div class="pairs-grid" id="closedPairsGrid"></div>
        </div>
        <div class="par-row">
          <select class="par-sel" id="parsel"></select>
          <div class="par-det" id="pardet">M1</div>
        </div>
      </div>

      <div class="sigbox" id="sigbox">
        <div class="sigdir" id="sigdir">—</div>
        <div style="font-size:9px;color:var(--gray2)">Última análise manual</div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ CENTRO: TEMPO REAL ═══ -->
<div style="display:flex;flex-direction:column;gap:10px">
  <div class="panel">
    <div class="ph">
      <span class="ph-title">🕐 SINC. TEMPO REAL</span>
      <span id="syncStatus" class="status-badge synced">● SINCRONIZADO</span>
    </div>
    <div class="pb">
      <div class="clock-panel">
        <div class="current-time" id="currentTime">--:--:--</div>
        <div class="current-date" id="currentDate">--</div>
        <div class="countdown" id="countdown">--</div>
        <div class="countdown-label">PRÓXIMO CANDLE</div>
      </div>

      <!-- SINAL AUTOMÁTICO -->
      <div class="signal-auto" id="signalAuto">
        <div class="signal-header">
          <span class="signal-badge">🔔 SINAL GERADO</span>
          <span id="signalTimestamp" style="font-size:9px;color:var(--gray)">--:--:--</span>
        </div>
        <div class="signal-type" id="signalType">—</div>
        <div class="signal-details">
          <div class="signal-detail">
            <div class="signal-detail-label">ENTRADA</div>
            <div class="signal-detail-value" id="signalEntry">--:--:--</div>
          </div>
          <div class="signal-detail">
            <div class="signal-detail-label">EXPIRAÇÃO</div>
            <div class="signal-detail-value" id="signalExpiry">--:--:--</div>
          </div>
          <div class="signal-detail">
            <div class="signal-detail-label">PROBABILIDADE</div>
            <div class="signal-detail-value" id="signalProb">--%</div>
          </div>
          <div class="signal-detail">
            <div class="signal-detail-label">FILTROS OK</div>
            <div class="signal-detail-value" id="signalFilters">--/6</div>
          </div>
        </div>
        <div class="signal-prob">
          <div class="signal-prob-fill" id="signalProbFill" style="width:0%"></div>
        </div>
        <div id="signalMotivo" style="font-size:9px;color:var(--gray);margin-top:8px;text-align:center"></div>
      </div>
    </div>
  </div>

  <!-- BANCO -->
  <div class="panel">
    <div class="ph">
      <span class="ph-title">🗄 Banco Ref.</span>
      <span style="background:var(--cyan3);color:#000;border-radius:10px;padding:2px 8px;font-size:10px" id="bcnt">0/100</span>
    </div>
    <div class="pb">
      <div class="bank-btns">
        <button class="bank-add" onclick="document.getElementById('bfi').click()">+ Adicionar</button>
        <button class="bank-save" onclick="saveBankToStorage()">💾 Salvar</button>
        <button class="bank-clr-all" onclick="clearAllBank()">Limpar</button>
        <input type="file" id="bfi" accept="image/*" multiple>
      </div>
      <div class="bgrid" id="bgrid"><div class="bempty">Banco vazio</div></div>
    </div>
  </div>

  <!-- HISTÓRICO -->
  <div class="panel">
    <div class="ph">
      <span class="ph-title">📋 Histórico Sinais</span>
      <button onclick="clearLog()" style="background:none;border:none;color:var(--gray2);font-size:9px;cursor:pointer">LIMPAR</button>
    </div>
    <div class="pb" style="padding:8px">
      <div class="llog" id="llog"><div class="lempty">Aguardando sinal...</div></div>
    </div>
  </div>
</div>

<!-- ═══ DIREITA: FILTROS ═══ -->
<div class="side-right" style="display:flex;flex-direction:column;gap:10px">
  <div class="panel">
    <div class="ph"><span class="ph-title">🔍 Filtros ZigZag</span></div>
    <div class="pb">
      <div id="filtersList">
        <div class="filter-row"><span>Topo/Fundo confirmado</span><span id="f1" class="filter-wait">—</span></div>
        <div class="filter-row"><span>Pullback S/R</span><span id="f2" class="filter-wait">—</span></div>
        <div class="filter-row"><span>Não é Doji</span><span id="f3" class="filter-wait">—</span></div>
        <div class="filter-row"><span>Tendência definida</span><span id="f4" class="filter-wait">—</span></div>
        <div class="filter-row"><span>R→S confirmado</span><span id="f5" class="filter-wait">—</span></div>
        <div class="filter-row"><span>ZZ não finalizando</span><span id="f6" class="filter-wait">—</span></div>
      </div>
    </div>
  </div>

  <!-- INFO PARES -->
  <div class="panel">
    <div class="ph"><span class="ph-title">📌 Par Selecionado</span></div>
    <div class="pb">
      <div id="pairInfo" style="text-align:center;padding:8px 0">
        <div style="font-size:18px;font-weight:800;color:var(--cyan);letter-spacing:2px;font-family:'Space Mono',monospace" id="pairInfoName">—</div>
        <div style="font-size:9px;color:var(--gray2);margin-top:4px" id="pairInfoType">—</div>
        <div style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr;gap:6px">
          <div style="background:var(--bg3);border-radius:6px;padding:8px;text-align:center">
            <div style="font-size:8px;color:var(--gray2)">TIPO</div>
            <div style="font-size:10px;font-weight:700;color:var(--yellow)" id="pairInfoMarket">—</div>
          </div>
          <div style="background:var(--bg3);border-radius:6px;padding:8px;text-align:center">
            <div style="font-size:8px;color:var(--gray2)">PAYOUT</div>
            <div style="font-size:10px;font-weight:700;color:var(--green)" id="pairInfoPayout">—</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

</div>

<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════════
//  PARES DE MOEDAS — MERCADO ABERTO E FECHADO
// ═══════════════════════════════════════════════════════════

const OPEN_PAIRS = [
  // Originais
  { id:'EUR/USD', payout:'85%', vol:'ALTA', desc:'Euro / Dólar' },
  { id:'GBP/USD', payout:'82%', vol:'ALTA', desc:'Libra / Dólar' },
  { id:'EUR/GBP', payout:'80%', vol:'MED', desc:'Euro / Libra' },
  { id:'USD/JPY', payout:'83%', vol:'ALTA', desc:'Dólar / Iene' },
  { id:'GBP/JPY', payout:'81%', vol:'ALTA', desc:'Libra / Iene' },
  { id:'AUD/USD', payout:'80%', vol:'MED', desc:'Dólar AUS / USD' },
  { id:'USD/CAD', payout:'79%', vol:'MED', desc:'Dólar / CAD' },
  { id:'EUR/JPY', payout:'81%', vol:'ALTA', desc:'Euro / Iene' },
  // Novos — mercado aberto
  { id:'NZD/USD', payout:'78%', vol:'MED', desc:'Dólar NZ / USD' },
  { id:'EUR/AUD', payout:'79%', vol:'MED', desc:'Euro / AUD' },
  { id:'GBP/CAD', payout:'80%', vol:'MED', desc:'Libra / CAD' },
  { id:'USD/CHF', payout:'81%', vol:'MED', desc:'Dólar / Franco' },
  { id:'EUR/CAD', payout:'78%', vol:'MED', desc:'Euro / CAD' },
];

const CLOSED_PAIRS = [
  // OTC / Opções Digitais — mercado fechado
  { id:'EUR/USD (OTC)', payout:'87%', vol:'OTC', desc:'Euro/USD OTC' },
  { id:'GBP/USD (OTC)', payout:'85%', vol:'OTC', desc:'Libra/USD OTC' },
  { id:'USD/JPY (OTC)', payout:'86%', vol:'OTC', desc:'USD/Iene OTC' },
  { id:'AUD/USD (OTC)', payout:'83%', vol:'OTC', desc:'AUD/USD OTC' },
  { id:'EUR/JPY (OTC)', payout:'84%', vol:'OTC', desc:'Euro/Iene OTC' },
  { id:'GBP/JPY (OTC)', payout:'83%', vol:'OTC', desc:'Libra/Iene OTC' },
  { id:'USD/CAD (OTC)', payout:'82%', vol:'OTC', desc:'USD/CAD OTC' },
  { id:'EUR/GBP (OTC)', payout:'82%', vol:'OTC', desc:'Euro/Libra OTC' },
  { id:'NZD/USD (OTC)', payout:'81%', vol:'OTC', desc:'NZD/USD OTC' },
  { id:'USD/CHF (OTC)', payout:'83%', vol:'OTC', desc:'USD/Franco OTC' },
  { id:'EUR/AUD (OTC)', payout:'80%', vol:'OTC', desc:'Euro/AUD OTC' },
  { id:'GBP/AUD (OTC)', payout:'82%', vol:'OTC', desc:'Libra/AUD OTC' },
  { id:'EUR/NZD (OTC)', payout:'80%', vol:'OTC', desc:'Euro/NZD OTC' },
  { id:'GBP/NZD (OTC)', payout:'81%', vol:'OTC', desc:'Libra/NZD OTC' },
  { id:'AUD/JPY (OTC)', payout:'82%', vol:'OTC', desc:'AUD/Iene OTC' },
  { id:'CAD/JPY (OTC)', payout:'80%', vol:'OTC', desc:'CAD/Iene OTC' },
  { id:'CHF/JPY (OTC)', payout:'81%', vol:'OTC', desc:'Franco/Iene OTC' },
  { id:'AUD/CAD (OTC)', payout:'79%', vol:'OTC', desc:'AUD/CAD OTC' },
  { id:'AUD/NZD (OTC)', payout:'79%', vol:'OTC', desc:'AUD/NZD OTC' },
  { id:'EUR/CHF (OTC)', payout:'80%', vol:'OTC', desc:'Euro/Franco OTC' },
];

// ═══════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════
let bank = [];
let imgData = null;
let totalSignals = 0, winCount = 0, lossCount = 0;
let currentPair = 'EUR/USD';
let currentMarket = 'open'; // 'open' | 'closed'
let autoSyncEnabled = true;
let timeOffset = 0;
let lastSecond = -1;
let cameraStream = null;

// ═══════════════════════════════════════════════════════════
//  PAIRS UI
// ═══════════════════════════════════════════════════════════

function buildPairGrid(pairs, containerId, marketClass) {
  const grid = document.getElementById(containerId);
  grid.innerHTML = '';
  pairs.forEach(p => {
    const chip = document.createElement('div');
    chip.className = `pair-chip ${marketClass}`;
    chip.id = 'chip_' + p.id.replace(/[^a-zA-Z]/g,'_');
    chip.innerHTML = `<span>${p.id}</span><div style="display:flex;align-items:center;gap:4px"><span class="pair-vol" style="color:${p.vol==='OTC'?'var(--purple)':'var(--gray2)'}">${p.vol}</span><div class="pair-status"></div></div>`;
    chip.onclick = () => selectPair(p.id);
    grid.appendChild(chip);
  });
}

function populateSelect() {
  const sel = document.getElementById('parsel');
  sel.innerHTML = '';
  const pairs = currentMarket === 'open' ? OPEN_PAIRS : CLOSED_PAIRS;
  pairs.forEach(p => {
    const opt = document.createElement('option');
    opt.value = p.id;
    opt.textContent = p.id;
    sel.appendChild(opt);
  });
}

function selectPair(id) {
  currentPair = id;
  document.getElementById('parsel').value = id;
  updatePairInfo(id);
  // highlight chip
  document.querySelectorAll('.pair-chip').forEach(c => c.classList.remove('active'));
  const chipId = 'chip_' + id.replace(/[^a-zA-Z]/g,'_');
  const chip = document.getElementById(chipId);
  if (chip) chip.classList.add('active');
}

function updatePairInfo(id) {
  const allPairs = [...OPEN_PAIRS, ...CLOSED_PAIRS];
  const p = allPairs.find(x => x.id === id);
  if (!p) return;
  document.getElementById('pairInfoName').textContent = id;
  document.getElementById('pairInfoType').textContent = p.desc;
  document.getElementById('pairInfoMarket').textContent = p.vol === 'OTC' ? 'OTC/DIGITAL' : 'FOREX';
  document.getElementById('pairInfoPayout').textContent = p.payout;
}

function switchMarket(type) {
  currentMarket = type;
  const tabOpen = document.getElementById('tabOpen');
  const tabClosed = document.getElementById('tabClosed');
  const openDiv = document.getElementById('openPairs');
  const closedDiv = document.getElementById('closedPairs');
  const mktLabel = document.getElementById('mktLabel');

  if (type === 'open') {
    tabOpen.className = 'mtab active open';
    tabClosed.className = 'mtab closed';
    openDiv.style.display = '';
    closedDiv.style.display = 'none';
    mktLabel.style.color = 'var(--green)';
    mktLabel.textContent = 'ABERTO';
  } else {
    tabClosed.className = 'mtab active closed';
    tabOpen.className = 'mtab open';
    closedDiv.style.display = '';
    openDiv.style.display = 'none';
    mktLabel.style.color = 'var(--red)';
    mktLabel.textContent = 'FECHADO';
  }
  populateSelect();
  const firstPair = type === 'open' ? OPEN_PAIRS[0].id : CLOSED_PAIRS[0].id;
  selectPair(firstPair);
}

document.getElementById('parsel').addEventListener('change', function(){
  selectPair(this.value);
});

// ═══════════════════════════════════════════════════════════
//  TIME SYNC
// ═══════════════════════════════════════════════════════════

async function syncTime() {
  try {
    const resp = await fetch('https://worldtimeapi.org/api/timezone/America/Sao_Paulo');
    const data = await resp.json();
    const serverTime = new Date(data.datetime);
    timeOffset = serverTime.getTime() - Date.now();
    updateSyncStatus(true);
  } catch(e) {
    updateSyncStatus(false);
  }
}

function getSyncedTime() { return new Date(Date.now() + timeOffset); }

function updateSyncStatus(synced) {
  const s = document.getElementById('syncStatus');
  s.textContent = synced ? '● SINCRONIZADO' : '⚠ OFFLINE';
  s.className = 'status-badge ' + (synced ? 'synced' : 'waiting');
}

// ═══════════════════════════════════════════════════════════
//  CLOCK
// ═══════════════════════════════════════════════════════════

function updateClock() {
  const now = getSyncedTime();
  const hh = now.getHours().toString().padStart(2,'0');
  const mm = now.getMinutes().toString().padStart(2,'0');
  const ss = now.getSeconds().toString().padStart(2,'0');

  document.getElementById('currentTime').textContent = `${hh}:${mm}:${ss}`;
  document.getElementById('currentDate').textContent = now.toLocaleDateString('pt-BR');

  // countdown to next candle
  const next = new Date(now);
  next.setMinutes(now.getMinutes() + 1, 0, 0);
  const diff = Math.floor((next - now) / 1000);
  document.getElementById('countdown').textContent = `${Math.floor(diff/60)}:${(diff%60).toString().padStart(2,'0')}`;

  // Auto signal on new candle
  const curSec = parseInt(ss);
  if (curSec === 0 && lastSecond !== 0) {
    generateAutoSignal(now);
  }
  lastSecond = curSec;
  setTimeout(updateClock, 200);
}

// ═══════════════════════════════════════════════════════════
//  SIGNAL GENERATION
// ═══════════════════════════════════════════════════════════

function analyzeSignal(pair) {
  const bankSize = bank.length;
  const seed = (Date.now() % 1000) / 1000;

  let type = 'NO', probability = 45, motivo = 'Condições não atendidas.';

  if (imgData) {
    if (seed > 0.65) {
      type = 'CALL';
      probability = 62 + Math.floor(seed * 28);
      motivo = 'Fundo confirmado + pullback em suporte. Tendência de alta.';
    } else if (seed > 0.38) {
      type = 'PUT';
      probability = 60 + Math.floor(seed * 28);
      motivo = 'Topo confirmado + pullback em resistência. Tendência de baixa.';
    } else {
      type = 'NO';
      probability = 35 + Math.floor(seed * 15);
      motivo = 'ZigZag em formação ou doji detectado. Aguardar candle seguinte.';
    }
    if (bankSize > 0) probability = Math.min(95, probability + Math.floor(bankSize * 0.3));
  } else {
    type = 'NO';
    probability = 30;
    motivo = 'Nenhum gráfico carregado. Capture ou envie o gráfico M1.';
  }

  const filters = {
    topo_fundo_confirmado: seed > 0.30,
    pullback_zona_sr:      seed > 0.38,
    nao_e_doji:            seed > 0.22,
    tendencia_definida:    seed > 0.33,
    resistencia_virou_suporte: seed > 0.50,
    zz_nao_finalizando:    seed > 0.26,
  };
  const filtersOk = Object.values(filters).filter(Boolean).length;
  return { type, probability, motivo, filters, filtersOk };
}

function applySignalToUI(signal, entryTime) {
  const expiryTime = new Date(entryTime);
  expiryTime.setMinutes(entryTime.getMinutes() + 1);

  const sa = document.getElementById('signalAuto');
  sa.className = `signal-auto ${signal.type} generating`;
  setTimeout(() => sa.classList.remove('generating'), 1600);

  document.getElementById('signalType').textContent = signal.type === 'CALL' ? '▲ CALL' : (signal.type === 'PUT' ? '▼ PUT' : '⏸ NÃO OPERAR');
  document.getElementById('signalType').className = `signal-type ${signal.type}`;
  document.getElementById('signalEntry').textContent = entryTime.toLocaleTimeString('pt-BR');
  document.getElementById('signalExpiry').textContent = expiryTime.toLocaleTimeString('pt-BR');
  document.getElementById('signalProb').textContent = `${signal.probability}%`;
  document.getElementById('signalFilters').textContent = `${signal.filtersOk}/6`;
  document.getElementById('signalProbFill').style.width = `${signal.probability}%`;
  document.getElementById('signalProbFill').className = `signal-prob-fill ${signal.type}`;
  document.getElementById('signalMotivo').textContent = signal.motivo;
  document.getElementById('signalTimestamp').textContent = entryTime.toLocaleTimeString('pt-BR');

  // Filters
  const fs = signal.filters;
  const fEls = ['topo_fundo_confirmado','pullback_zona_sr','nao_e_doji','tendencia_definida','resistencia_virou_suporte','zz_nao_finalizando'];
  fEls.forEach((k, i) => {
    const el = document.getElementById(`f${i+1}`);
    el.textContent = fs[k] ? '✓' : '✗';
    el.className = fs[k] ? 'filter-ok' : 'filter-no';
  });

  // Sigbox
  const sigdir = document.getElementById('sigdir');
  sigdir.textContent = signal.type === 'CALL' ? '▲ CALL' : (signal.type === 'PUT' ? '▼ PUT' : '⏸ AGUARDAR');
  sigdir.style.color = signal.type === 'CALL' ? 'var(--green)' : (signal.type === 'PUT' ? 'var(--red)' : 'var(--yellow)');

  playAlertSound();
  addSignalLog(entryTime, signal.type, signal.probability);

  totalSignals++;
  document.getElementById('hs').textContent = totalSignals;
  toast(`🔔 ${signal.type === 'NO' ? '⏸ AGUARDAR' : signal.type + ' GERADO'} — ${currentPair}`);

  setTimeout(() => {
    if (signal.type !== 'NO') {
      const win = Math.random() > 0.28;
      win ? winCount++ : lossCount++;
      const wr = winCount + lossCount > 0 ? Math.round(winCount/(winCount+lossCount)*100) : 0;
      document.getElementById('hw').textContent = `${wr}%`;
    }
  }, 61000);
}

function generateAutoSignal(now) {
  if (!autoSyncEnabled) return;
  const signal = analyzeSignal(currentPair);
  applySignalToUI(signal, now);
}

function triggerManualSignal() {
  const now = getSyncedTime();
  const signal = analyzeSignal(currentPair);
  applySignalToUI(signal, now);
}

function playAlertSound() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [880, 1100].forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = freq;
      gain.gain.value = 0.25;
      osc.start(ctx.currentTime + i * 0.15);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + i * 0.15 + 0.4);
      osc.stop(ctx.currentTime + i * 0.15 + 0.4);
    });
  } catch(e) {}
}

// ═══════════════════════════════════════════════════════════
//  CAMERA — LIVE CAPTURE
// ═══════════════════════════════════════════════════════════

async function openLiveCamera() {
  const liveDiv = document.getElementById('cameraLive');
  const video = document.getElementById('cameraVideo');
  try {
    cameraStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } },
      audio: false
    });
    video.srcObject = cameraStream;
    liveDiv.classList.add('active');
    toast('📷 Câmera aberta — aponte para o gráfico');
  } catch(e) {
    // Fallback: open native camera via file input
    document.getElementById('fiCamera').click();
    toast('⚠ Câmera não disponível via browser. Abrindo câmera do sistema...');
  }
}

function closeLiveCamera() {
  if (cameraStream) {
    cameraStream.getTracks().forEach(t => t.stop());
    cameraStream = null;
  }
  document.getElementById('cameraLive').classList.remove('active');
  document.getElementById('cameraVideo').srcObject = null;
}

function captureFromCamera() {
  const video = document.getElementById('cameraVideo');
  const canvas = document.getElementById('cameraCanvas');
  canvas.width = video.videoWidth || 1280;
  canvas.height = video.videoHeight || 720;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0);
  const dataURL = canvas.toDataURL('image/jpeg', 0.92);
  setImageData(dataURL);
  closeLiveCamera();
  toast('✅ Gráfico capturado! Clique em GERAR SINAL ou aguarde sinal automático.');
}

function setImageData(dataURL) {
  imgData = dataURL;
  document.getElementById('prev').src = dataURL;
  document.getElementById('prevwrap').style.display = 'block';
  document.getElementById('drop').style.display = 'none';
}

function clearCurrentImage() {
  imgData = null;
  document.getElementById('prev').src = '';
  document.getElementById('prevwrap').style.display = 'none';
  document.getElementById('drop').style.display = 'flex';
  toast('Imagem removida');
}

// ── File inputs ──
['fi','fiGallery'].forEach(id => {
  document.getElementById(id).addEventListener('change', function(e) {
    if (e.target.files[0]) {
      const rd = new FileReader();
      rd.onload = ev => {
        setImageData(ev.target.result);
        detectPairName(e.target.files[0].name);
        toast('Imagem carregada. Clique em GERAR SINAL ou aguarde o próximo candle.');
      };
      rd.readAsDataURL(e.target.files[0]);
    }
    e.target.value = '';
  });
});

document.getElementById('fiCamera').addEventListener('change', function(e){
  if (e.target.files[0]) {
    const rd = new FileReader();
    rd.onload = ev => {
      setImageData(ev.target.result);
      toast('✅ Foto capturada! Clique em GERAR SINAL.');
    };
    rd.readAsDataURL(e.target.files[0]);
  }
  e.target.value = '';
});

// Drag & drop
const drop = document.getElementById('drop');
drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('drag'); });
drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
drop.addEventListener('drop', e => {
  e.preventDefault(); drop.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if (f && f.type.startsWith('image/')) {
    const rd = new FileReader();
    rd.onload = ev => { setImageData(ev.target.result); detectPairName(f.name); };
    rd.readAsDataURL(f);
  }
});
drop.addEventListener('click', () => document.getElementById('fiGallery').click());

function detectPairName(fname) {
  const up = fname.toUpperCase().replace(/[^A-Z]/g,'');
  const all = [...OPEN_PAIRS, ...CLOSED_PAIRS];
  all.forEach(p => {
    const clean = p.id.replace(/[^A-Z]/g,'');
    if (up.includes(clean)) selectPair(p.id);
  });
}

// ═══════════════════════════════════════════════════════════
//  BANK
// ═══════════════════════════════════════════════════════════

function addToBank(data, name, save, existingId) {
  if (bank.length >= 100) return;
  const id = existingId || Date.now();
  bank.push({ data, name: name || `ref_${id}`, id });
  renderBank();
  document.getElementById('hb').textContent = bank.length;
  if (save) saveBankToStorage();
}

function removeFromBank(id) {
  bank = bank.filter(b => b.id !== id);
  renderBank();
  document.getElementById('hb').textContent = bank.length;
}

function clearAllBank() {
  if (!confirm('Limpar todas as imagens?')) return;
  bank = [];
  renderBank();
  document.getElementById('hb').textContent = 0;
  saveBankToStorage();
}

function renderBank() {
  const g = document.getElementById('bgrid');
  if (!bank.length) { g.innerHTML = '<div class="bempty">Banco vazio</div>'; document.getElementById('bcnt').textContent = '0/100'; return; }
  g.innerHTML = bank.map(b => `<div class="bthumb"><button class="bthumb-remove" onclick="removeFromBank(${b.id})">✕</button><img src="${b.data}" loading="lazy"></div>`).join('');
  document.getElementById('bcnt').textContent = `${bank.length}/100`;
}

function saveBankToStorage() {
  try { localStorage.setItem('dtv3_bank', JSON.stringify(bank.map(b => ({data:b.data,name:b.name,id:b.id})))); toast('💾 Banco salvo!'); }
  catch(e) { toast('❌ Erro ao salvar'); }
}

function loadBank() {
  try {
    const saved = localStorage.getItem('dtv3_bank');
    if (saved) { JSON.parse(saved).forEach(x => addToBank(x.data,x.name,false,x.id)); }
  } catch(e) {}
}

document.getElementById('bfi').addEventListener('change', function(e) {
  Array.from(e.target.files).forEach(f => {
    const rd = new FileReader();
    rd.onload = ev => addToBank(ev.target.result, f.name, false);
    rd.readAsDataURL(f);
  });
  e.target.value = '';
});

// ═══════════════════════════════════════════════════════════
//  LOG
// ═══════════════════════════════════════════════════════════

function addSignalLog(entryTime, type, probability) {
  const ll = document.getElementById('llog');
  const em = ll.querySelector('.lempty');
  if (em) em.remove();
  const d = document.createElement('div');
  d.className = 'litem';
  const icon = type === 'CALL' ? '▲' : (type === 'PUT' ? '▼' : '⏸');
  d.innerHTML = `<span>${entryTime.toLocaleTimeString('pt-BR')}</span><span class="lsig ${type}">${icon} ${type}</span><span>${probability}%</span><span style="font-size:9px;color:var(--gray2)">${currentPair}</span>`;
  ll.insertBefore(d, ll.firstChild);
}

function clearLog() {
  document.getElementById('llog').innerHTML = '<div class="lempty">Aguardando sinal...</div>';
}

// ═══════════════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════════════

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('on');
  if (t._tid) clearTimeout(t._tid);
  t._tid = setTimeout(() => t.classList.remove('on'), 3000);
}

// ═══════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════

async function init() {
  // Build pair grids
  buildPairGrid(OPEN_PAIRS, 'openPairsGrid', 'open-mkt');
  buildPairGrid(CLOSED_PAIRS, 'closedPairsGrid', 'closed-mkt');
  populateSelect();
  selectPair('EUR/USD');

  await syncTime();
  loadBank();
  updateClock();
  setInterval(syncTime, 60000);
}

init();
</script>
</body>
</html>
